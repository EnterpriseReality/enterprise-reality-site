---
import Callout from "../components/Callout.astro";
import StatusBadge from "../components/StatusBadge.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const progression = [
  "Applications and Events",
  "Governed Representation",
  "Evidence",
  "Reasoning",
  "Policy",
  "Decision",
  "Authorised Action",
];

const platformItems = [
  {
    name: "Studio",
    status: "Planned" as const,
    text: "Authoring and governance workspace for Enterprise Reality knowledge.",
  },
  {
    name: "Runtime",
    status: "In Development" as const,
    text: "Current programme focus for governed corpus, graph, reasoning and automation foundations.",
  },
  {
    name: "Decision Services",
    status: "Concept" as const,
    text: "Future product expression for explainable decision support across enterprise contexts.",
  },
  {
    name: "Explorer",
    status: "Planned" as const,
    text: "Planned public and internal navigation experience for governed knowledge.",
  },
  {
    name: "Connect",
    status: "Planned" as const,
    text: "Planned enablement layer for responsible integration with existing systems.",
  },
  {
    name: "Assistant",
    status: "Research" as const,
    text: "Future assistance model for retrieval, explanation and investigation. It does not decide, approve or execute.",
  },
];

const statusLabels = [
  "Released",
  "In Development",
  "Planned",
  "Research",
  "Concept",
] as const;

const outcomes = [
  {
    title: "Explainable Decisions",
    text: "Decisions can be traced to governed representations, evidence, policy and reasoning paths.",
  },
  {
    title: "Consistent Policy Application",
    text: "Policy is treated as an enterprise responsibility rather than an inconsistent afterthought in disconnected workflows.",
  },
  {
    title: "Governed Automation",
    text: "Automation is constrained by evidence, authority and permission before action is taken.",
  },
  {
    title: "Audit-ready Traceability",
    text: "The path from identity and evidence to decision and authorised action remains reviewable.",
  },
  {
    title: "Trustworthy AI Assistance",
    text: "AI can help retrieve and explain governed knowledge without becoming the source of constitutional truth.",
  },
];
---

<BaseLayout
  title="Enterprise Reality"
  description="Enterprise Reality is the Constitutional Decision Platform for regulated enterprises, connecting governed knowledge, operational evidence and enterprise policy."
  canonicalPath="/"
>
  <section class="hero page-hero section">
    <div class="container page-hero__inner">
      <div>
        <p class="eyebrow">Enterprise Reality</p>
        <h1>Enterprise Reality</h1>
        <p class="hero__position">
          The Constitutional Decision Platform for Regulated Enterprises
        </p>
        <p class="lead">
          Enterprise Reality connects governed knowledge, operational evidence
          and enterprise policy to produce explainable decisions and authorised
          action across existing systems.
        </p>
        <div class="hero__actions" aria-label="Primary actions">
          <a href="/platform/" class="button">Explore the Architecture</a>
          <a href="/why-enterprise-reality/" class="button button--secondary">
            Why Enterprise Reality
          </a>
        </div>
      </div>
      <Callout title="Public status">
        <p>
          This website presents approved public narrative for an in-development
          programme. It does not present live operational use or customer use.
        </p>
      </Callout>
    </div>
  </section>

  <section class="section section--muted" aria-labelledby="problem-heading">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">The Problem</p>
        <h2 id="problem-heading">
          Operational systems do not create shared constitutional understanding
        </h2>
      </div>
      <p class="lead">
        Enterprises already operate many systems for records, work, reporting
        and execution. The missing layer is often a shared governed
        understanding of identity, evidence, policy, decisions, authority and
        execution across those systems.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="progression-heading">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Enterprise Reality Progression</p>
        <h2 id="progression-heading">
          From operational events to authorised action
        </h2>
      </div>
      <ol class="flow">
        {progression.map((item) => <li>{item}</li>)}
      </ol>
    </div>
  </section>

  <section class="section section--muted" aria-labelledby="platform-heading">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Platform at a Glance</p>
        <h2 id="platform-heading">
          A constitutional platform with explicit maturity labels
        </h2>
      </div>
      <div class="grid grid--3">
        {
          platformItems.map((item) => (
            <article class="card">
              <h3>{item.name}</h3>
              <StatusBadge status={item.status} />
              <p>{item.text}</p>
            </article>
          ))
        }
      </div>
      <div class="status-legend" aria-label="Capability status labels">
        {statusLabels.map((status) => <StatusBadge status={status} />)}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="matters-heading">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Why it Matters</p>
        <h2 id="matters-heading">Outcomes depend on governed understanding</h2>
      </div>
      <div class="grid grid--3">
        {
          outcomes.map((outcome) => (
            <article class="outcome-card">
              <h3>{outcome.title}</h3>
              <p>{outcome.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--muted" aria-labelledby="closing-heading">
    <div class="container">
      <h2 id="closing-heading" class="closing-statement">
        Understand before change.
      </h2>
    </div>
  </section>
</BaseLayout>

<style>
  .hero__position {
    color: var(--text-primary);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-heading);
    max-width: 34rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .button {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
    border: 1px solid var(--surface-strong);
    border-radius: var(--radius-sm);
    background: var(--surface-strong);
    color: var(--text-inverse);
    padding: 0 var(--space-4);
    font-weight: var(--weight-semibold);
    text-decoration: none;
  }

  .button:hover {
    color: var(--text-inverse);
  }

  .button--secondary {
    background: transparent;
    color: var(--text-primary);
  }

  .button--secondary:hover {
    color: var(--text-primary);
  }

  .card .status-badge {
    margin-bottom: var(--space-4);
  }

  .status-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-5);
  }
</style>
