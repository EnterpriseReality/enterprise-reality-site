---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogType?: "website" | "article";
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const siteName = "Enterprise Reality";
const siteOrigin = "https://www.enterprisereality.org";
const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  ogType = "website",
  structuredData,
} = Astro.props;
const composedTitle = title === siteName ? title : `${title} | ${siteName}`;
const canonicalUrl = new URL(canonicalPath, siteOrigin).toString();
const isHomePage = canonicalPath === "/";
const organisationStructuredData = {
  "@type": "Organization",
  "@id": `${siteOrigin}/#organization`,
  name: siteName,
  url: siteOrigin,
};
const webPageStructuredData = {
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: composedTitle,
  description,
  isPartOf: {
    "@id": `${siteOrigin}/#website`,
  },
  publisher: {
    "@id": `${siteOrigin}/#organization`,
  },
};
const websiteStructuredData = {
  "@type": "WebSite",
  "@id": `${siteOrigin}/#website`,
  name: siteName,
  url: siteOrigin,
  publisher: {
    "@id": `${siteOrigin}/#organization`,
  },
};
const breadcrumbStructuredData = !isHomePage
  ? {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: `${siteOrigin}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: title,
          item: canonicalUrl,
        },
      ],
    }
  : undefined;
const contentStructuredDataItems = (
  Array.isArray(structuredData)
    ? structuredData
    : structuredData
      ? [structuredData]
      : []
).map((item) => {
  const { "@context": _context, ...data } = item;

  return data;
});
const structuredDataItems = [
  organisationStructuredData,
  websiteStructuredData,
  webPageStructuredData,
  breadcrumbStructuredData,
  ...contentStructuredDataItems,
].filter(Boolean);
const structuredDataGraph = {
  "@context": "https://schema.org",
  "@graph": structuredDataItems,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{composedTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={composedTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={composedTitle} />
    <meta name="twitter:description" content={description} />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredDataGraph)}
    />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <div class="site-shell">
      <SiteHeader />
      <main id="main-content" tabindex="-1">
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
