---
const year = new Date().getUTCFullYear();
const footerLinks = [
  { href: "/", label: "Home" },
  { href: "/why-enterprise-reality/", label: "Why Enterprise Reality" },
  { href: "/platform/", label: "Platform" },
  { href: "/architecture/", label: "Architecture" },
  { href: "/industries/", label: "Industries" },
  { href: "/research/", label: "Research" },
  { href: "/roadmap/", label: "Roadmap" },
  {
    href: "/constitution-driven-engineering/",
    label: "Constitution-Driven Engineering",
  },
  { href: "/about/", label: "About" },
];
---

<footer class="site-footer">
  <div class="site-footer__inner container">
    <div>
      <p class="site-footer__brand">Enterprise Reality</p>
      <p>A governed public website for the Enterprise Reality Programme.</p>
    </div>
    <nav aria-label="Footer">
      {footerLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
    <p class="site-footer__meta">
      &copy; {year} Enterprise Reality Programme. Deployment deferred.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--border-subtle);
    background: var(--surface-strong);
    color: var(--text-inverse);
  }

  .site-footer__inner {
    display: grid;
    gap: var(--space-5);
    padding-block: var(--space-7);
  }

  .site-footer p {
    color: color-mix(in srgb, var(--text-inverse) 82%, transparent);
    margin-bottom: var(--space-2);
  }

  .site-footer__brand {
    color: var(--text-inverse) !important;
    font-weight: var(--weight-bold);
  }

  .site-footer a {
    color: var(--text-inverse);
  }

  .site-footer nav {
    display: grid;
    gap: var(--space-2);
  }

  .site-footer__meta {
    font-size: var(--text-sm);
  }

  @media (min-width: 56rem) {
    .site-footer__inner {
      grid-template-columns: 1fr auto;
    }

    .site-footer__meta {
      grid-column: 1 / -1;
    }
  }
</style>
