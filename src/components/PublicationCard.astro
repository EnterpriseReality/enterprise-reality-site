---
import StatusBadge from "./StatusBadge.astro";
import type { PublicationStatus } from "../utilities/status";

interface Props {
  id: string;
  title: string;
  subtitle?: string;
  summary: string;
  version: string;
  status: PublicationStatus;
  publicationDate?: Date;
  readingTime?: string;
  href: string;
  featured?: boolean;
}

const {
  id,
  title,
  subtitle,
  summary,
  version,
  status,
  publicationDate,
  readingTime,
  href,
  featured = false,
} = Astro.props;

const dateLabel = publicationDate
  ? new Intl.DateTimeFormat("en-GB", {
      day: "numeric",
      month: "long",
      year: "numeric",
    }).format(publicationDate)
  : "Not yet published";
---

<article class="publication-card" data-featured={featured ? "true" : "false"}>
  <div class="publication-card__meta">
    <span class="publication-card__id">{id}</span>
    <StatusBadge status={status} />
  </div>
  <h3>
    <a href={href}>{title}</a>
  </h3>
  {subtitle && <p class="publication-card__subtitle">{subtitle}</p>}
  <p>{summary}</p>
  <dl class="publication-card__facts" aria-label={`${id} publication metadata`}>
    <div>
      <dt>Version</dt>
      <dd>{version}</dd>
    </div>
    <div>
      <dt>Publication Date</dt>
      <dd>{dateLabel}</dd>
    </div>
    {
      readingTime && (
        <div>
          <dt>Reading Time</dt>
          <dd>{readingTime}</dd>
        </div>
      )
    }
  </dl>
  {featured && <p class="publication-card__featured">Featured publication</p>}
</article>

<style>
  .publication-card {
    display: grid;
    gap: var(--space-3);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--surface-panel);
    padding: var(--space-5);
  }

  .publication-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .publication-card__id {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
  }

  .publication-card h3 {
    margin-bottom: 0;
  }

  .publication-card h3 a {
    color: var(--text-primary);
    text-decoration-color: var(--border-strong);
  }

  .publication-card__subtitle {
    margin-bottom: 0;
    color: var(--text-secondary);
    font-weight: var(--weight-semibold);
  }

  .publication-card__facts {
    display: grid;
    gap: var(--space-2);
    margin: 0;
  }

  .publication-card__facts div {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .publication-card__facts dt {
    color: var(--text-secondary);
    font-weight: var(--weight-semibold);
  }

  .publication-card__facts dd {
    margin: 0;
  }

  .publication-card__featured {
    width: fit-content;
    margin-bottom: 0;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-2);
    color: var(--text-primary);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
  }
</style>
